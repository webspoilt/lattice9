# Lattice9 — Environment Variables Example

# Database (PostgreSQL)
DATABASE_URL=postgresql://lattice9:l9_secret@localhost:5432/lattice9

# Authentication & Security
JWT_SECRET=generate_a_random_string_here
LATTICE9_ENGINE_KEY=sovereign-l9-secret-2026

# Neo4j Graph Intelligence
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=l9_graph_secret

# Object Storage (MinIO)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=l9_admin
MINIO_SECRET_KEY=l9_secret_storage

# AI Core (Local Ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Port configuration
PORT=3000
ENGINE_PORT=8000
